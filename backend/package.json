    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^10.0.1",
    "@google/generative-ai": "^0.2.1",
    "@prisma/client": "^5.9.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "dotenv": "^17.2.3",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.13",
