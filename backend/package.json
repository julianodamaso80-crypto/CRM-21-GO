    "@types/node": "^20.11.16",
    "@types/nodemailer": "^7.0.9",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prisma": "^5.9.1",
    "tsup": "^8.0.1",
