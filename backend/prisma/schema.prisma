// 21Go Protecao Veicular - Database Schema
// Redesigned for vehicle protection association (not generic SaaS)
// Models based on 10 AI agents + 4 roles (admin/gestor/vendedor/operacao)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// IDENTITY & ACCESS
// ============================================================================

model Company {
  id       String  @id @default(uuid())
  name     String  // "21Go Protecao Veicular"
  slug     String  @unique
  logo     String?
  website  String?
  email    String?
  phone    String?
  address  String?
  city     String?
  state    String?
  zipCode  String? @map("zip_code")
  settings Json    @default("{}") // configuracoes gerais da empresa

  isActive Boolean @default(true) @map("is_active")

  // Relationships
  users          User[]
  associados     Associado[]
  leads          Lead[]
  cotacoes       Cotacao[]
  vehicles       Vehicle[]
  sinistros      Sinistro[]
  oficinas       Oficina[]
  vistorias      Vistoria[]
  boletos        Boleto[]
  npsSurveys     NpsSurvey[]
  indicacoes     Indicacao[]
  projetos       Projeto[]
  conversations  Conversation[]
  messages       Message[]
  aiAgents       AIAgent[]
  knowledgeBases KnowledgeBase[]
  automacoes     Automacao[]
  auditLogs      AuditLog[]
  ouvidorias     Ouvidoria[]

  // Pipefy-like
  pipes Pipe[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String  // bcrypt hashed — LGPD: dado de autenticacao
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  avatar    String?
  phone     String? // LGPD: dado pessoal
  role      String  @default("vendedor") // admin, gestor, vendedor, operacao
  isActive  Boolean @default(true) @map("is_active")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Auth
  refreshTokens RefreshToken[]

  // CRM relationships
  assignedLeads         Lead[]         @relation("VendedorLeads")
  assignedConversations Conversation[] @relation("AssignedConversations")
  sentMessages          Message[]      @relation("SentMessages")
  sinistrosResponsavel  Sinistro[]     @relation("ResponsavelSinistro")
  vistoriasRealizadas   Vistoria[]     @relation("VistoriadorVistorias")

  // Pipefy
  createdCards  Card[] @relation("CreatedCards")
  assignedCards Card[] @relation("AssignedCards")

  // Associados vendidos por este user
  associadosVendidos Associado[] @relation("VendedorAssociados")

  // Audit
  auditLogs AuditLog[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@map("users")
  @@index([companyId])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
  @@index([userId])
}

// ============================================================================
// ASSOCIADOS (membros da associacao)
// ============================================================================

model Associado {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Identificacao — LGPD: dados pessoais sensiveis
  nome           String
  cpf            String?  // LGPD: dado pessoal sensivel — unique por empresa
  rg             String?  // LGPD: dado pessoal
  dataNascimento DateTime? @map("data_nascimento")
  email          String?  // LGPD: dado pessoal
  telefone       String?  // LGPD: dado pessoal
  whatsapp       String?  // LGPD: dado pessoal

  // Endereco
  endereco String?
  bairro   String?
  cidade   String?
  uf       String? // sigla: RJ, SP, etc
  cep      String?

  // Status de associacao
  status             String    @default("em_adesao") // ativo, inativo, inadimplente, cancelado, em_adesao
  dataAdesao         DateTime? @map("data_adesao")
  dataCancelamento   DateTime? @map("data_cancelamento")
  motivoCancelamento String?   @map("motivo_cancelamento")

  // Integracao Hinova (SGA)
  hinovaId String? @map("hinova_id")

  // MGM — Indicacao (self-reference)
  indicadoPorId   String?    @map("indicado_por_id")
  indicadoPor     Associado? @relation("IndicacaoMGM", fields: [indicadoPorId], references: [id], onDelete: SetNull)
  indicados       Associado[] @relation("IndicacaoMGM")
  totalIndicacoes Int        @default(0) @map("total_indicacoes")
  descontoMgm     Float      @default(0) @map("desconto_mgm") // 0 a 100 (%)

  // Vendedor responsavel
  vendedorId String? @map("vendedor_id")
  vendedor   User?   @relation("VendedorAssociados", fields: [vendedorId], references: [id], onDelete: SetNull)

  // NPS (cache do ultimo)
  npsScore  Int?      @map("nps_score")
  ultimoNps DateTime? @map("ultimo_nps")

  // Origem / Rastreamento (Agente Trafego)
  origem      String? // google_ads, meta_ads, instagram, site_organico, indicacao, whatsapp, direto, outro
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")

  // Metadata
  tags         String[] @default([])
  customFields Json     @default("{}") @map("custom_fields")

  // Relationships
  vehicles   Vehicle[]
  leads      Lead[]
  cotacoes   Cotacao[]
  sinistros  Sinistro[]
  vistorias  Vistoria[]
  boletos    Boleto[]
  npsSurveys NpsSurvey[]
  conversations Conversation[]

  // MGM — como indicador
  indicacoesFeitas   Indicacao[] @relation("Indicador")
  indicacaoResultado Indicacao[] @relation("AssociadoResultante")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("associados")
  @@unique([companyId, cpf])
  @@index([companyId])
  @@index([hinovaId])
  @@index([vendedorId])
  @@index([status])
  @@index([origem])
  @@index([nome])
}

// ============================================================================
// VEHICLES (Protecao Veicular)
// ============================================================================

model Vehicle {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  associadoId String    @map("associado_id")
  associado   Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  // Dados do veiculo
  placa         String
  renavam       String?
  chassi        String?
  marca         String
  modelo        String
  anoFabricacao Int     @map("ano_fabricacao")
  anoModelo     Int     @map("ano_modelo")
  cor           String?
  combustivel   String? // gasolina, etanol, flex, diesel, eletrico, hibrido
  tipo          String  @default("carro") // carro, moto, caminhonete, van, caminhao

  // FIPE (Agente Pre-Venda)
  codigoFipe String? @map("codigo_fipe")
  valorFipe  Float?  @map("valor_fipe")

  // Plano de protecao
  plano       String // basico, completo, premium
  valorMensal Float? @map("valor_mensal")

  // Rastreador
  temRastreador   Boolean @default(false) @map("tem_rastreador")
  rastreadorMarca String? @map("rastreador_marca")

  // Vistoria (status inline para consulta rapida)
  vistoriaStatus String    @default("pendente") @map("vistoria_status") // pendente, agendada, aprovada, reprovada
  vistoriaData   DateTime? @map("vistoria_data")

  // Status
  ativo Boolean @default(true)

  // Relationships
  sinistros Sinistro[]
  vistorias Vistoria[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vehicles")
  @@unique([companyId, placa])
  @@index([associadoId])
  @@index([codigoFipe])
}

// ============================================================================
// LEADS & COTACOES (Agente Pre-Venda)
// ============================================================================

model Lead {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Dados do lead — LGPD: dados pessoais
  nome      String
  telefone  String?  // LGPD: dado pessoal
  email     String?  // LGPD: dado pessoal
  whatsapp  String?

  // Veiculo de interesse (pre-venda)
  placaInteresse  String? @map("placa_interesse")
  marcaInteresse  String? @map("marca_interesse")
  modeloInteresse String? @map("modelo_interesse")
  anoInteresse    Int?    @map("ano_interesse")

  // Cotacao FIPE (Agente Pre-Venda calcula)
  valorFipeConsultado Float?  @map("valor_fipe_consultado")
  cotacaoValor        Float?  @map("cotacao_valor")
  cotacaoPlano        String? @map("cotacao_plano") // basico, completo, premium
  cotacaoEnviada      Boolean @default(false) @map("cotacao_enviada")
  cotacaoData         DateTime? @map("cotacao_data")

  // Qualificacao
  qualificadoPor    String? @map("qualificado_por") // agente_ia, vendedor, manual
  scoreQualificacao Int     @default(0) @map("score_qualificacao")

  // Vendedor atribuido
  vendedorId String? @map("vendedor_id")
  vendedor   User?   @relation("VendedorLeads", fields: [vendedorId], references: [id], onDelete: SetNull)

  // Conversa com agente IA
  agenteIaConversaId String? @map("agente_ia_conversa_id")

  // Funil de vendas
  etapaFunil String @default("novo") @map("etapa_funil")
  // novo, qualificado, cotacao_enviada, negociacao, fechado, perdido
  motivoPerda String? @map("motivo_perda")

  // Origem / Rastreamento (Agente Trafego)
  origem      String? // google_ads, meta_ads, instagram, site_organico, indicacao, whatsapp, direto
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmContent  String? @map("utm_content")
  utmTerm     String? @map("utm_term")

  // Click IDs e tracking avançado (para offline conversions)
  gclid     String?
  fbclid    String?
  fbp       String? // cookie _fbp
  fbc       String? // cookie _fbc
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  // Conversão (quando lead vira cliente)
  status          String @default("lead") // lead, cliente_ativo, cancelado
  valorCompra     Float?    @map("valor_compra")
  produtoComprado String?   @map("produto_comprado")
  dataConversao   DateTime? @map("data_conversao")

  // Flags de envio de conversão offline
  metaCapiSent     Boolean   @default(false) @map("meta_capi_sent")
  metaCapiSentAt   DateTime? @map("meta_capi_sent_at")
  googleAdsSent    Boolean   @default(false) @map("google_ads_sent")
  googleAdsSentAt  DateTime? @map("google_ads_sent_at")

  // Associado resultante (quando lead vira associado)
  associadoId String?    @map("associado_id")
  associado   Associado? @relation(fields: [associadoId], references: [id], onDelete: SetNull)

  // Cotacoes formais
  cotacoes Cotacao[]

  // Indicacao que gerou este lead (back-reference)
  indicacaoOrigem Indicacao?

  // Conversations
  conversations Conversation[]

  // Follow-up automático (WhatsApp via Evolution API)
  followUpEnviado Boolean   @default(false) @map("follow_up_enviado")
  followUpData    DateTime? @map("follow_up_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("leads")
  @@index([companyId])
  @@index([email])
  @@index([telefone])
  @@index([vendedorId])
  @@index([etapaFunil])
  @@index([origem])
}

model Cotacao {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  leadId      String? @map("lead_id")
  lead        Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  associadoId String?    @map("associado_id")
  associado   Associado? @relation(fields: [associadoId], references: [id], onDelete: SetNull)

  // Dados do veiculo cotado
  veiculoDados Json @default("{}") @map("veiculo_dados")
  // { placa, marca, modelo, ano, cor, combustivel, tipo }

  // Calculo (Agente Pre-Venda)
  valorFipe   Float   @map("valor_fipe")
  plano       String  // basico, completo, premium
  taxaPlano   Float   @map("taxa_plano")   // ex: 0.018, 0.028, 0.038
  taxaAdmin   Float   @map("taxa_admin")   // ex: 35.00
  valorMensal Float   @map("valor_mensal") // resultado final

  // Validade e status
  validade DateTime
  status   String @default("pendente") // pendente, enviada, aceita, recusada, expirada

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cotacoes")
  @@index([companyId])
  @@index([leadId])
  @@index([associadoId])
  @@index([status])
}

// ============================================================================
// PLATE LOOKUP CACHE (API Brasil — consulta de placa + FIPE)
// ============================================================================

model PlateLookup {
  id        String  @id @default(uuid())
  placa     String
  success   Boolean
  fromCache Boolean @default(false) @map("from_cache")

  // Dados do veiculo (quando sucesso)
  marca     String?
  modelo    String?
  ano       String?
  fipeValue Float?  @map("fipe_value")

  // Resultado completo (JSON) ou erro
  result       Json    @default("{}")
  errorMessage String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("plate_lookups")
  @@index([placa, createdAt])
  @@index([createdAt])
}

// ============================================================================
// SINISTROS & OFICINAS (Agente Sinistros + Agente Operacao)
// ============================================================================

model Sinistro {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  associadoId String    @map("associado_id")
  associado   Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  veiculoId String  @map("veiculo_id")
  veiculo   Vehicle @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  // Ocorrencia
  tipo            String // roubo, furto, colisao, incendio, terceiros
  descricao       String? @db.Text
  dataOcorrencia  DateTime @map("data_ocorrencia")
  localOcorrencia String?  @map("local_ocorrencia")
  boletimOcorrencia String? @map("boletim_ocorrencia")

  // Status (fluxo do Agente Sinistros)
  // aberto > analise > aprovado/negado > oficina > aguardando_peca > reparo > pronto > entregue > encerrado
  status String @default("aberto")

  // Oficina
  oficinaId String?  @map("oficina_id")
  oficina   Oficina? @relation(fields: [oficinaId], references: [id], onDelete: SetNull)

  // Guincho
  guinchoSolicitado Boolean @default(false) @map("guincho_solicitado")
  guinchoRealizado  Boolean @default(false) @map("guincho_realizado")

  // Custo
  custoEstimado Float? @map("custo_estimado")
  custoReal     Float? @map("custo_real")

  // Datas
  dataAbertura     DateTime  @default(now()) @map("data_abertura")
  dataEncerramento DateTime? @map("data_encerramento")

  // Responsavel (operacao/gestor)
  responsavelId String? @map("responsavel_id")
  responsavel   User?   @relation("ResponsavelSinistro", fields: [responsavelId], references: [id], onDelete: SetNull)

  // Fotos (antes/durante/depois — obrigatorias por regra do Agente Sinistros)
  fotos Json @default("[]") // [{ url, etapa, descricao, dataUpload }]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sinistros")
  @@index([companyId])
  @@index([associadoId])
  @@index([veiculoId])
  @@index([status])
  @@index([dataAbertura])
  @@index([oficinaId])
}

model Oficina {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  nome         String
  endereco     String?
  cidade       String?
  uf           String?
  telefone     String?
  responsavel  String?
  especialidade String? // funilaria, pintura, mecanica_geral, eletrica, vidros
  ativa        Boolean @default(true)
  avaliacaoMedia Float? @map("avaliacao_media") // 0-5

  // Relationships
  sinistros Sinistro[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("oficinas")
  @@index([companyId])
  @@index([ativa])
}

// ============================================================================
// VISTORIAS (Agente Operacao)
// ============================================================================

model Vistoria {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  associadoId String    @map("associado_id")
  associado   Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  veiculoId String  @map("veiculo_id")
  veiculo   Vehicle @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  // Tipo e status
  tipo   String @default("adesao") // adesao, periodica, sinistro
  status String @default("pendente") // pendente, agendada, em_analise, aprovada, reprovada

  // Datas
  dataAgendada  DateTime? @map("data_agendada")
  dataRealizada DateTime? @map("data_realizada")

  // Vistoriador
  vistoriadorId String? @map("vistoriador_id")
  vistoriador   User?   @relation("VistoriadorVistorias", fields: [vistoriadorId], references: [id], onDelete: SetNull)

  // Evidencias
  fotos       Json    @default("[]") // [{ url, angulo, descricao }]
  observacoes String? @db.Text
  motivoReprovacao String? @map("motivo_reprovacao")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vistorias")
  @@index([companyId])
  @@index([associadoId])
  @@index([veiculoId])
  @@index([status])
}

// ============================================================================
// BOLETOS (Agente Financeiro)
// ============================================================================

model Boleto {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  associadoId String    @map("associado_id")
  associado   Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  valor          Float
  dataVencimento DateTime  @map("data_vencimento")
  dataPagamento  DateTime? @map("data_pagamento")
  status         String    @default("pendente") // pendente, pago, atrasado, cancelado

  // Integracao Hinova SGC
  hinovaBoletoId String? @map("hinova_boleto_id")
  linkPagamento  String? @map("link_pagamento")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("boletos")
  @@index([companyId])
  @@index([associadoId])
  @@index([status])
  @@index([dataVencimento])
}

// ============================================================================
// NPS (Agente Retencao + Pos-Venda)
// ============================================================================

model NpsSurvey {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  associadoId String    @map("associado_id")
  associado   Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  score   Int     // 0-10
  comment String?
  channel String  // whatsapp, email, app, manual
  tipo    String  @default("periodico") // onboarding, periodico, pos_sinistro, pos_atendimento

  respondidoEm DateTime? @map("respondido_em")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("nps_surveys")
  @@index([companyId])
  @@index([associadoId])
  @@index([score])
}

// ============================================================================
// INDICACOES MGM (Agente Crescimento)
// ============================================================================

model Indicacao {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Quem indicou
  indicadorId String    @map("indicador_id")
  indicador   Associado @relation("Indicador", fields: [indicadorId], references: [id], onDelete: Cascade)

  // Pessoa indicada
  indicadoNome     String @map("indicado_nome")
  indicadoTelefone String? @map("indicado_telefone") // LGPD: dado pessoal
  indicadoEmail    String? @map("indicado_email")    // LGPD: dado pessoal

  // Progresso
  leadId String? @unique @map("lead_id")
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  associadoResultanteId String?    @map("associado_resultante_id")
  associadoResultante   Associado? @relation("AssociadoResultante", fields: [associadoResultanteId], references: [id], onDelete: SetNull)

  // Status
  status String @default("pendente")
  // pendente, lead_criado, em_negociacao, convertido, expirado

  descontoAplicado Float?    @map("desconto_aplicado") // % aplicado ao indicador
  dataIndicacao    DateTime  @default(now()) @map("data_indicacao")
  dataConversao    DateTime? @map("data_conversao")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("indicacoes")
  @@index([companyId])
  @@index([indicadorId])
  @@index([status])
}

// ============================================================================
// PROJETOS (Gestao interna)
// ============================================================================

model Projeto {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  titulo      String
  descricao   String?  @db.Text
  status      String   @default("backlog") // backlog, todo, doing, review, done
  prioridade  String   @default("media")   // alta, media, baixa
  tags        String[] @default([])
  responsavel String?
  dataEntrega DateTime? @map("data_entrega")
  progresso   Int       @default(0) // 0-100

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("projetos")
  @@index([companyId])
  @@index([status])
}

// ============================================================================
// CONVERSATIONS & MESSAGES (Inbox / Chat)
// ============================================================================

model Conversation {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Pode ser de associado ou lead
  associadoId String?    @map("associado_id")
  associado   Associado? @relation(fields: [associadoId], references: [id], onDelete: SetNull)

  leadId String? @map("lead_id")
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  channel String @default("whatsapp") // whatsapp, chat, email
  status  String @default("open")     // open, assigned, resolved, closed

  // Atribuicao
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Agente IA ativo nesta conversa
  agenteIaId String? @map("agente_ia_id")

  lastMessageAt DateTime? @map("last_message_at")

  // Relationships
  messages Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("conversations")
  @@index([companyId])
  @@index([associadoId])
  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
}

model Message {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  content String @db.Text

  // Quem enviou
  sender String // associado, agente, vendedor, sistema

  // Se enviado por user
  senderId String? @map("sender_id")
  senderUser User?  @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
  @@index([conversationId])
  @@index([createdAt])
}

// ============================================================================
// AI AGENTS & KNOWLEDGE BASE (10 agentes da squad)
// ============================================================================

model AIAgent {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  nome        String
  agentId     String  @map("agent_id") // slug: 21go-chief, agente-pre-venda, etc
  descricao   String?
  icon        String?
  tier        Int     @default(1) // 0=orchestrator, 1=specialist
  squad       String  @default("21go-squad")
  type        String  @default("internal") // internal, customer_facing
  provider    String  @default("anthropic") // openai, anthropic, google
  model       String  @default("claude-sonnet-4-6")
  temperature Float   @default(0.5)
  maxTokens   Int     @default(2000) @map("max_tokens")
  systemPrompt String @db.Text @map("system_prompt")

  // Permissoes (RBAC dos agentes)
  allowedRoles  Json @default("[]") @map("allowed_roles")  // ["vendedor","gestor","admin"]
  allowedScopes Json @default("[]") @map("allowed_scopes") // ["associados","leads","analytics"]
  permissions   Json @default("{}") // { canCreateLeads, canUpdateLeads, canTransferToHuman, ... }

  // Knowledge Base vinculada
  knowledgeBaseId String?        @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_agents")
  @@index([companyId])
  @@index([agentId])
}

model KnowledgeBase {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  nome      String
  descricao String?

  // Relationships
  documentos KnowledgeDocument[]
  agents     AIAgent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("knowledge_bases")
  @@index([companyId])
}

model KnowledgeDocument {
  id              String        @id @default(uuid())
  knowledgeBaseId String        @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  nome       String
  sourceType String @map("source_type") // pdf, txt, url, text, crm_data
  fileName   String? @map("file_name")
  fileSize   Int?    @map("file_size")
  status     String  @default("pending") // pending, processing, completed, failed

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("knowledge_documents")
  @@index([knowledgeBaseId])
}

// ============================================================================
// AUTOMACOES
// ============================================================================

model Automacao {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  nome       String
  trigger    String  // evento que dispara
  conditions Json    @default("[]") // condicoes para executar
  actions    Json    @default("[]") // acoes a executar
  ativa      Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("automacoes")
  @@index([companyId])
}

// ============================================================================
// AUDIT LOG (Cyber Chief — LGPD compliance)
// ============================================================================

model AuditLog {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId    String? @map("user_id")
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String  // create, update, delete, login, logout, export, access_sensitive_data
  resource  String  // associado, lead, sinistro, boleto, etc
  resourceId String? @map("resource_id")
  description String?
  changes   Json?   // { before: {}, after: {} }
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([companyId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

// ============================================================================
// PIPEFY-LIKE (Pipes, Phases, Cards — processos genericos)
// ============================================================================

model Pipe {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  icon        String?
  color       String @default("#1B4DA1")
  status      String @default("active") // active, archived
  tags        String[] @default([])

  phases           Phase[]
  fieldDefinitions FieldDefinition[]
  cards            Card[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pipes")
  @@index([companyId])
}

model Phase {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  pipeId String @map("pipe_id")
  pipe   Pipe   @relation(fields: [pipeId], references: [id], onDelete: Cascade)

  name        String
  color       String @default("#6B7280")
  position    Int
  probability Int    @default(0) // 0-100
  isWon       Boolean @default(false) @map("is_won")
  isLost      Boolean @default(false) @map("is_lost")

  cards Card[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("phases")
  @@index([pipeId, position])
}

model FieldDefinition {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  pipeId String @map("pipe_id")
  pipe   Pipe   @relation(fields: [pipeId], references: [id], onDelete: Cascade)

  name       String
  label      String
  type       String // text, number, date, select, checkbox, currency, email, phone, url
  required   Boolean @default(false)
  position   Int     @default(0)
  configJson Json    @default("{}") @map("config_json")

  values CardFieldValue[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("field_definitions")
  @@unique([pipeId, name])
}

model Card {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  pipeId         String @map("pipe_id")
  pipe           Pipe   @relation(fields: [pipeId], references: [id], onDelete: Cascade)

  currentPhaseId String @map("current_phase_id")
  currentPhase   Phase  @relation(fields: [currentPhaseId], references: [id])

  title       String
  description String?
  status      String @default("active") // active, done, archived

  createdById  String @map("created_by_id")
  createdBy    User   @relation("CreatedCards", fields: [createdById], references: [id])

  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedCards", fields: [assignedToId], references: [id], onDelete: SetNull)

  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")

  fieldValues CardFieldValue[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cards")
  @@index([companyId, pipeId])
  @@index([currentPhaseId])
  @@index([status])
}

model CardFieldValue {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  cardId            String          @map("card_id")
  card              Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)

  fieldDefinitionId String          @map("field_definition_id")
  fieldDefinition   FieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  valueJson Json @default("null") @map("value_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("card_field_values")
  @@unique([cardId, fieldDefinitionId])
}

// ============================================================================
// OUVIDORIA
// ============================================================================

model Ouvidoria {
  id        String @id @default(uuid())
  companyId String @default("company-21go") @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tipo      String // reclamacao, sugestao, denuncia
  nome      String? // null para denuncia anonima
  telefone  String? // null para denuncia anonima
  assunto   String? // usado na denuncia
  mensagem  String? // reclamacao/sugestao
  comentario String? // denuncia
  arquivos  Json    @default("[]") // nomes dos arquivos

  status    String  @default("pendente") // pendente, em_analise, resolvido
  resposta  String? // resposta interna da diretoria

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ouvidoria")
  @@index([companyId])
  @@index([tipo])
  @@index([status])
  @@index([createdAt])
}
