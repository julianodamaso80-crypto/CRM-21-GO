{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "npm run build && cd backend && npx prisma migrate deploy"
  },
  "deploy": {
    "startCommand": "cd backend && node dist/server.mock.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
