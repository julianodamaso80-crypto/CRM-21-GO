{
  "exportFormatVersion": 2,
  "containerVersion": {
    "variable": [
      {
        "name": "CONST - GA4 Measurement ID",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "G-XXXXXXXXXX" }]
      },
      {
        "name": "CONST - Meta Pixel ID",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "000000000000000" }]
      },
      {
        "name": "CONST - Google Ads Conversion ID",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "AW-0000000000" }]
      },
      {
        "name": "CONST - Google Ads Lead Label",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "XXXXXXXXX" }]
      },
      {
        "name": "CONST - Server Container URL",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "https://sgtm.21go.site" }]
      },
      {
        "name": "DLV - event_id",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "event_id" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - plan_name",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "plan_name" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - plan_value",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "plan_value" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - vehicle_marca",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "vehicle_marca" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - vehicle_modelo",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "vehicle_modelo" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - fipe_value",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "fipe_value" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - click_origin",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "click_origin" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - gclid",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "gclid" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - fbclid",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "fbclid" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - utm_source",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "utm_source" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - utm_medium",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "utm_medium" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "DLV - utm_campaign",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "utm_campaign" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      }
    ],
    "trigger": [
      {
        "name": "CE - page_view",
        "type": "customEvent",
        "customEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view" }
            ]
          }
        ]
      },
      {
        "name": "CE - cotacao_inicio",
        "type": "customEvent",
        "customEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_inicio" }
            ]
          }
        ]
      },
      {
        "name": "CE - cotacao_completa",
        "type": "customEvent",
        "customEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ]
      },
      {
        "name": "CE - whatsapp_click",
        "type": "customEvent",
        "customEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "whatsapp_click" }
            ]
          }
        ]
      }
    ],
    "tag": [
      {
        "name": "GA4 - Config",
        "type": "gaawc",
        "parameter": [
          { "type": "TEMPLATE", "key": "measurementId", "value": "{{CONST - GA4 Measurement ID}}" },
          { "type": "BOOLEAN", "key": "sendPageView", "value": "true" },
          { "type": "TEMPLATE", "key": "serverContainerUrl", "value": "{{CONST - Server Container URL}}" }
        ],
        "firingTriggerId": ["CE - page_view"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "GA4 - Event - cotacao_inicio",
        "type": "gaawe",
        "parameter": [
          { "type": "TEMPLATE", "key": "eventName", "value": "cotacao_inicio" },
          { "type": "TAG_REFERENCE", "key": "measurementId", "value": "GA4 - Config" },
          {
            "type": "LIST",
            "key": "eventParameters",
            "list": [
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "event_id" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - event_id}}" }
              ]}
            ]
          }
        ],
        "firingTriggerId": ["CE - cotacao_inicio"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "GA4 - Event - cotacao_completa",
        "type": "gaawe",
        "parameter": [
          { "type": "TEMPLATE", "key": "eventName", "value": "cotacao_completa" },
          { "type": "TAG_REFERENCE", "key": "measurementId", "value": "GA4 - Config" },
          {
            "type": "LIST",
            "key": "eventParameters",
            "list": [
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "event_id" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - event_id}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "plan_name" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - plan_name}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "value" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - plan_value}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "currency" },
                { "type": "TEMPLATE", "key": "value", "value": "BRL" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "vehicle_marca" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - vehicle_marca}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "vehicle_modelo" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - vehicle_modelo}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "fipe_value" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - fipe_value}}" }
              ]}
            ]
          }
        ],
        "firingTriggerId": ["CE - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "GA4 - Event - whatsapp_click",
        "type": "gaawe",
        "parameter": [
          { "type": "TEMPLATE", "key": "eventName", "value": "whatsapp_click" },
          { "type": "TAG_REFERENCE", "key": "measurementId", "value": "GA4 - Config" },
          {
            "type": "LIST",
            "key": "eventParameters",
            "list": [
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "event_id" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - event_id}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "click_origin" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - click_origin}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "plan_name" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - plan_name}}" }
              ]},
              { "type": "MAP", "map": [
                { "type": "TEMPLATE", "key": "name", "value": "value" },
                { "type": "TEMPLATE", "key": "value", "value": "{{DLV - plan_value}}" }
              ]}
            ]
          }
        ],
        "firingTriggerId": ["CE - whatsapp_click"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Google Ads - Conversion - Lead",
        "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{CONST - Google Ads Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "{{CONST - Google Ads Lead Label}}" },
          { "type": "TEMPLATE", "key": "conversionValue", "value": "{{DLV - plan_value}}" },
          { "type": "TEMPLATE", "key": "currencyCode", "value": "BRL" },
          { "type": "TEMPLATE", "key": "orderId", "value": "{{DLV - event_id}}" }
        ],
        "firingTriggerId": ["CE - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta Pixel - InitiateCheckout",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nif(typeof fbq!=='undefined'){\n  fbq('track','InitiateCheckout',{content_category:'protecao_veicular'},{eventID:{{DLV - event_id}}});\n}\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["CE - cotacao_inicio"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta Pixel - Lead",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nif(typeof fbq!=='undefined'){\n  fbq('track','Lead',{\n    content_name:{{DLV - vehicle_marca}}+' '+{{DLV - vehicle_modelo}},\n    content_category:{{DLV - plan_name}},\n    value:{{DLV - plan_value}},\n    currency:'BRL'\n  },{eventID:{{DLV - event_id}}});\n}\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["CE - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta Pixel - Contact",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nif(typeof fbq!=='undefined'){\n  fbq('track','Contact',{\n    content_category:{{DLV - plan_name}}||'geral',\n    value:{{DLV - plan_value}}||0,\n    currency:'BRL'\n  },{eventID:{{DLV - event_id}}});\n}\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["CE - whatsapp_click"],
        "tagFiringOption": "ONCE_PER_EVENT"
      }
    ]
  }
}
