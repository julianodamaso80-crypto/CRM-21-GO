{
  "exportFormatVersion": 2,
  "containerVersion": {
    "variable": [
      {
        "name": "CONST - Meta CAPI Access Token",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "EAAG_YOUR_META_ACCESS_TOKEN_HERE" }]
      },
      {
        "name": "CONST - Meta Pixel ID",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "000000000000000" }]
      },
      {
        "name": "CONST - GA4 Measurement ID",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "G-XXXXXXXXXX" }]
      },
      {
        "name": "CONST - Google Ads Conversion ID",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "AW-0000000000" }]
      },
      {
        "name": "CONST - Google Ads Lead Label",
        "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "XXXXXXXXX" }]
      },
      {
        "name": "ED - event_id",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "event_id" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - event_name",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "event_name" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - plan_name",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "plan_name" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - plan_value",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "value" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - page_location",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "page_location" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - ip_address",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "ip_override" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - user_agent",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "user_agent" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - fbclid",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "fbclid" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - fbc",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "_fbc" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - fbp",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "_fbp" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - gclid",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "gclid" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - email_hash",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "x-ga-ud-email" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - phone_hash",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "x-ga-ud-phone" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - vehicle_marca",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "vehicle_marca" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - vehicle_modelo",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "vehicle_modelo" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - fipe_value",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "fipe_value" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - click_origin",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "click_origin" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - utm_source",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "utm_source" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - utm_medium",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "utm_medium" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      },
      {
        "name": "ED - utm_campaign",
        "type": "v",
        "parameter": [
          { "type": "TEMPLATE", "key": "name", "value": "utm_campaign" },
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" }
        ]
      }
    ],
    "trigger": [
      {
        "name": "All Events",
        "type": "always"
      },
      {
        "name": "Event - page_view",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view" }
            ]
          }
        ],
        "filter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view" }
            ]
          }
        ]
      },
      {
        "name": "Event - cotacao_inicio",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_inicio" }
            ]
          }
        ],
        "filter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_inicio" }
            ]
          }
        ]
      },
      {
        "name": "Event - cotacao_completa",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ],
        "filter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ]
      },
      {
        "name": "Event - whatsapp_click",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "whatsapp_click" }
            ]
          }
        ],
        "filter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "whatsapp_click" }
            ]
          }
        ]
      },
      {
        "name": "Event - All 21Go Events",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view|cotacao_inicio|cotacao_completa|whatsapp_click" }
            ]
          }
        ],
        "filter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view|cotacao_inicio|cotacao_completa|whatsapp_click" }
            ]
          }
        ]
      }
    ],
    "tag": [
      {
        "name": "GA4 - Server Forward",
        "type": "gaawc",
        "parameter": [
          { "type": "TEMPLATE", "key": "measurementId", "value": "{{CONST - GA4 Measurement ID}}" },
          { "type": "BOOLEAN", "key": "sendPageView", "value": "true" }
        ],
        "firingTriggerId": ["All Events"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta CAPI - PageView",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<!-- Meta CAPI: PageView\n     SUBSTITUIR por template Facebook CAPI do Stape.io\n     Pixel={{CONST - Meta Pixel ID}} Token={{CONST - Meta CAPI Access Token}}\n     Event=PageView EventID={{ED - event_id}}\n     URL={{ED - page_location}} IP={{ED - ip_address}} UA={{ED - user_agent}}\n     FBC={{ED - fbc}} FBP={{ED - fbp}}\n-->"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["Event - page_view"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta CAPI - InitiateCheckout",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<!-- Meta CAPI: InitiateCheckout\n     SUBSTITUIR por template Facebook CAPI do Stape.io\n     Pixel={{CONST - Meta Pixel ID}} Token={{CONST - Meta CAPI Access Token}}\n     Event=InitiateCheckout EventID={{ED - event_id}}\n     URL={{ED - page_location}} IP={{ED - ip_address}} UA={{ED - user_agent}}\n     FBC={{ED - fbc}} FBP={{ED - fbp}} FBCLID={{ED - fbclid}}\n-->"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["Event - cotacao_inicio"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta CAPI - Lead",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<!-- Meta CAPI: Lead\n     SUBSTITUIR por template Facebook CAPI do Stape.io\n     Pixel={{CONST - Meta Pixel ID}} Token={{CONST - Meta CAPI Access Token}}\n     Event=Lead EventID={{ED - event_id}}\n     URL={{ED - page_location}} IP={{ED - ip_address}} UA={{ED - user_agent}}\n     FBC={{ED - fbc}} FBP={{ED - fbp}} FBCLID={{ED - fbclid}}\n     Email={{ED - email_hash}} Phone={{ED - phone_hash}}\n     Value={{ED - plan_value}} Currency=BRL\n     ContentName={{ED - vehicle_marca}} {{ED - vehicle_modelo}}\n     ContentCategory={{ED - plan_name}}\n-->"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["Event - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta CAPI - Contact",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<!-- Meta CAPI: Contact\n     SUBSTITUIR por template Facebook CAPI do Stape.io\n     Pixel={{CONST - Meta Pixel ID}} Token={{CONST - Meta CAPI Access Token}}\n     Event=Contact EventID={{ED - event_id}}\n     URL={{ED - page_location}} IP={{ED - ip_address}} UA={{ED - user_agent}}\n     FBC={{ED - fbc}} FBP={{ED - fbp}} FBCLID={{ED - fbclid}}\n     Email={{ED - email_hash}} Phone={{ED - phone_hash}}\n     Value={{ED - plan_value}} Currency=BRL\n     ContentCategory={{ED - plan_name}} ClickOrigin={{ED - click_origin}}\n-->"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["Event - whatsapp_click"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Google Ads Enhanced - Lead",
        "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{CONST - Google Ads Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "{{CONST - Google Ads Lead Label}}" },
          { "type": "TEMPLATE", "key": "conversionValue", "value": "{{ED - plan_value}}" },
          { "type": "TEMPLATE", "key": "currencyCode", "value": "BRL" },
          { "type": "TEMPLATE", "key": "orderId", "value": "{{ED - event_id}}" }
        ],
        "firingTriggerId": ["Event - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      }
    ]
  }
}
