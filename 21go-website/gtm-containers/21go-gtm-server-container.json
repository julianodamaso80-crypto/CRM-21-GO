    "trigger": [
      {
        "triggerId": "1",
        "name": "All Events",
        "type": "always"
      },
      {
        "triggerId": "2",
        "name": "Event - cotacao_completa",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ],
        "filter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ]
      },
      {
        "triggerId": "3",
        "name": "Event - All 21Go Events",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view|cotacao_inicio|cotacao_completa|whatsapp_click" }
            ]
          }
        ],
        "filter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view|cotacao_inicio|cotacao_completa|whatsapp_click" }
            ]
          }
        ]
      }
    ],
    "tag": [
      {
        "tagId": "1",
        "name": "GA4 - Server Forward",
        "type": "gaawc",
        "parameter": [
          { "type": "TEMPLATE", "key": "measurementId", "value": "{{CONST - GA4 Measurement ID}}" },
          { "type": "BOOLEAN", "key": "sendPageView", "value": "true" }
        ],
        "firingTriggerId": ["1"],
        "tagFiringOption": "oncePerEvent"
      },
      {
        "tagId": "2",
        "name": "Meta CAPI - All Events (PAUSADA)",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<!-- Meta CAPI: SUBSTITUIR por template Facebook CAPI do Stape.io\n     Pixel ID: {{CONST - Meta Pixel ID}}\n     Access Token: {{CONST - Meta CAPI Access Token}}\n     Lookup: page_view=PageView, cotacao_inicio=InitiateCheckout, cotacao_completa=Lead, whatsapp_click=Contact\n     Event ID: {{ED - event_id}} (deduplicacao)\n     URL: {{ED - page_location}} IP: {{ED - ip_address}} UA: {{ED - user_agent}}\n     FBC: {{ED - fbc}} FBP: {{ED - fbp}} FBCLID: {{ED - fbclid}}\n     Email: {{ED - email_hash}} Phone: {{ED - phone_hash}}\n     Value: {{ED - plan_value}} Currency: BRL\n     PAUSADA ate ter Meta Pixel ID\n-->"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["3"],
        "tagFiringOption": "oncePerEvent",
        "paused": true
      },
      {
        "tagId": "3",
        "name": "GAds Enhanced - Cotacao Completa",
        "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{CONST - Google Ads Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "{{CONST - GAds Label Cotacao Completa}}" },
          { "type": "TEMPLATE", "key": "conversionValue", "value": "{{ED - plan_value}}" },
          { "type": "TEMPLATE", "key": "currencyCode", "value": "BRL" },
          { "type": "TEMPLATE", "key": "orderId", "value": "{{ED - event_id}}" }
        ],
        "firingTriggerId": ["2"],
        "tagFiringOption": "oncePerEvent"
      }
