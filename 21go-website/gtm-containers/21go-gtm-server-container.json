    "trigger": [
      {
        "name": "All Events",
        "type": "always"
      },
      {
        "name": "Event - cotacao_completa",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ],
        "filter": [
          {
            "type": "EQUALS",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "cotacao_completa" }
            ]
          }
        ]
      },
      {
        "name": "Event - All 21Go Events",
        "type": "always",
        "autoEventFilter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view|cotacao_inicio|cotacao_completa|whatsapp_click" }
            ]
          }
        ],
        "filter": [
          {
            "type": "MATCH_REGEX",
            "parameter": [
              { "type": "TEMPLATE", "key": "arg0", "value": "{{ED - event_name}}" },
              { "type": "TEMPLATE", "key": "arg1", "value": "page_view|cotacao_inicio|cotacao_completa|whatsapp_click" }
            ]
          }
        ]
      }
    ],
    "tag": [
      {
        "name": "GA4 - Server Forward",
        "type": "gaawc",
        "parameter": [
          { "type": "TEMPLATE", "key": "measurementId", "value": "{{CONST - GA4 Measurement ID}}" },
          { "type": "BOOLEAN", "key": "sendPageView", "value": "true" }
        ],
        "firingTriggerId": ["All Events"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta CAPI - All Events (PAUSADA - sem Pixel ID)",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<!-- Meta CAPI: SUBSTITUIR por template Facebook CAPI do Stape.io\n     Pixel ID: {{CONST - Meta Pixel ID}}\n     Access Token: {{CONST - Meta CAPI Access Token}}\n     Event Name: usar Lookup Table (page_view=PageView, cotacao_inicio=InitiateCheckout, cotacao_completa=Lead, whatsapp_click=Contact)\n     Event ID: {{ED - event_id}} (DEDUPLICACAO)\n     Action Source: website\n     URL: {{ED - page_location}}\n     IP: {{ED - ip_address}}\n     User Agent: {{ED - user_agent}}\n     FBC: {{ED - fbc}}\n     FBP: {{ED - fbp}}\n     FBCLID: {{ED - fbclid}}\n     Email Hash: {{ED - email_hash}}\n     Phone Hash: {{ED - phone_hash}}\n     Value: {{ED - plan_value}}\n     Currency: BRL\n     Content: {{ED - vehicle_marca}} {{ED - vehicle_modelo}}\n     Category: {{ED - plan_name}}\n\n     IMPORTANTE: Tag PAUSADA ate ter Meta Pixel ID.\n     Apos obter Pixel ID: atualizar CONST, instalar template Stape, despausar.\n-->"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["Event - All 21Go Events"],
        "tagFiringOption": "ONCE_PER_EVENT",
        "paused": true
      },
      {
        "name": "GAds Enhanced - Cotacao Completa",
        "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{CONST - Google Ads Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "{{CONST - GAds Label Cotacao Completa}}" },
          { "type": "TEMPLATE", "key": "conversionValue", "value": "{{ED - plan_value}}" },
          { "type": "TEMPLATE", "key": "currencyCode", "value": "BRL" },
          { "type": "TEMPLATE", "key": "orderId", "value": "{{ED - event_id}}" }
        ],
        "firingTriggerId": ["Event - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      }
    ]
