      {
        "name": "GAds - Remarketing",
        "type": "sp",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{CONST - Google Ads Conversion ID}}" }
        ],
        "firingTriggerId": ["All Pages"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta Pixel - Base (Init + PageView)",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\n!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?\nn.callMethod.apply(n,arguments):n.queue.push(arguments)};\nif(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';\nn.queue=[];t=b.createElement(e);t.async=!0;\nt.src=v;s=b.getElementsByTagName(e)[0];\ns.parentNode.insertBefore(t,s)}(window,document,'script',\n'https://connect.facebook.net/en_US/fbevents.js');\nfbq('init','{{CONST - Meta Pixel ID}}');\nfbq('track','PageView',{},{eventID:{{DLV - event_id}}});\n</script>\n<noscript><img height=\"1\" width=\"1\" style=\"display:none\" src=\"https://www.facebook.com/tr?id={{CONST - Meta Pixel ID}}&ev=PageView&noscript=1\"/></noscript>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["All Pages"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta Pixel - InitiateCheckout (Cotacao Inicio)",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nif(typeof fbq!=='undefined'){\n  fbq('track','InitiateCheckout',{\n    content_category:'protecao_veicular'\n  },{\n    eventID:{{DLV - event_id}}\n  });\n}\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["CE - cotacao_inicio"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "name": "Meta Pixel - Lead (Cotacao Completa)",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nif(typeof fbq!=='undefined'){\n  fbq('track','Lead',{\n    content_name:{{DLV - vehicle_marca}}+' '+{{DLV - vehicle_modelo}}+' '+{{DLV - vehicle_ano}},\n    content_category:{{DLV - plan_name}},\n    value:{{DLV - plan_value}},\n    currency:'BRL'\n  },{\n    eventID:{{DLV - event_id}}\n  });\n}\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["CE - cotacao_completa"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
