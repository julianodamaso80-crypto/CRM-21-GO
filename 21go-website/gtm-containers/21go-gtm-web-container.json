        "name": "Meta Pixel - Contact (WhatsApp Click)",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nif(typeof fbq!=='undefined'){\n  fbq('track','Contact',{\n    content_category:{{DLV - plan_name}}||'geral',\n    value:{{DLV - plan_value}}||0,\n    currency:'BRL'\n  },{\n    eventID:{{DLV - event_id}}\n  });\n}\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["CE - whatsapp_click"],
        "tagFiringOption": "ONCE_PER_EVENT"
      }
