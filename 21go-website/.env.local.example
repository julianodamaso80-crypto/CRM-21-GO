# ---------------------------------------------------------------------
# PowerCRM PowerAPI
# Token gerado em: app.powercrm.com.br > Minha Empresa > Integracoes > PowerAPI
# Crie um token NOVO chamado "21go-website" com:
#   - Conceder acesso a informacoes de contato do lead: ON
#   - Conceder acesso a relatorio de banco de dados: OFF
# ---------------------------------------------------------------------
POWERCRM_BASE_URL="https://api.powercrm.com.br"
POWERAPI_TOKEN=""

# Cooperativa default (Regional Marcos Alves). Buscar id via GET /api/cooperativa
# ou consultar com o suporte. Opcional.
POWERCRM_DEFAULT_COOP=""

# Powerlink default. Codigos atuais (Ferramentas > Powerlinks):
#   Site = (sem codigo, link direto)
#   Pagina de cotacao = (sem codigo)
#   Marcos Alves = P4lp6EOp
#   Renata Tenorio = 4QwWw1QV
POWERCRM_DEFAULT_PWRLNK=""

# IDs das origens (Personalizacao > Origens). Reativar antes de usar:
# Atuais visiveis (do relatorio de reconhecimento):
#   1583  Google      (INATIVO — reativar ou criar "Google Ads")
#   1585  Instagram   (INATIVO — reativar ou criar "Meta Ads - IG")
#   6469  Meta Ads    (INATIVO — reativar)
#   1584  Leads       (ATIVO)
#   1586  Pessoal (Indicacao)  (ATIVO)
POWERCRM_LEAD_SOURCE_GOOGLE="1583"
POWERCRM_LEAD_SOURCE_META="6469"
POWERCRM_LEAD_SOURCE_INSTAGRAM="1585"
POWERCRM_LEAD_SOURCE_DIRECT="1584"
POWERCRM_DEFAULT_LEAD_SOURCE="1584"

# ---------------------------------------------------------------------
# PowerCRM Webhook (entrada — venda concretizada)
# Cadastrar em: app.powercrm.com.br > Minha Empresa > Integracoes > Power Webhook
